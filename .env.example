# === DeepSeek V4 Flash API ===
# 用于诗词生成和运势分析（占卜师 + 诗人双角色）
# 获取方式：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="your-deepseek-api-key"

# === 阿里云百炼 通义万相 (Qwen Image) API ===
# 用于根据诗词意象生成水墨画海报
# 获取方式：https://bailian.console.aliyun.com → API Key 管理
DASHSCOPE_API_KEY="your-dashscope-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# Supabase 配置（在 Supabase Dashboard → Settings → API 中获取）
# 前端使用的环境变量需要 VITE_ 前缀
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# 后端使用的环境变量（Service Role Key 仅在 server.ts 中使用，不暴露给前端）
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
